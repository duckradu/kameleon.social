{
  "name": "@kameleon.social/backend",
  "version": "0.0.0",
  "author": "radu.dascalu@pm.me",
  "type": "module",
  "main": "dist/root.js",
  "scripts": {
    "dev": "tsx watch src/root.ts",
    "prebuild": "pnpm clean",
    "build": "tsc && tsc-alias",
    "start": "node dist/root.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rimraf dist",
    "db:generate-root": "tsx ./bin/generate-db-root.ts",
    "db:run": "tsx node_modules/drizzle-kit/bin.cjs",
    "db:check": "pnpm db:run check:pg --config=src/config/db.ts",
    "db:generate": "pnpm db:run generate:pg --config=src/config/db.ts",
    "db:push": "pnpm db:run push:pg --config=src/config/db.ts",
    "db:seed": "pnpm run db/seed.ts",
    "db:drop": "pnpm db:run drop --config=src/config/db.ts",
    "db:studio": "pnpm db:run studio --config=src/config/db.ts"
  },
  "dependencies": {
    "@fastify/autoload": "^5.8.0",
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^8.4.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/sensible": "^5.5.0",
    "@fastify/type-provider-typebox": "^3.5.0",
    "@panva/hkdf": "^1.1.1",
    "@sinclair/typebox": "^0.31.28",
    "argon2": "^0.31.2",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "dotenv-expand": "^10.0.0",
    "drizzle-orm": "^0.29.1",
    "drizzle-typebox": "^0.1.1",
    "env-schema": "^5.2.1",
    "fastify": "^4.24.3",
    "jose": "^5.1.3",
    "nanoid": "^5.0.3",
    "pino": "^8.16.2",
    "postgres": "^3.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.1",
    "drizzle-kit": "^0.20.6",
    "glob": "^10.3.10",
    "pg": "^8.11.3",
    "pino-pretty": "^10.2.3",
    "rimraf": "^5.0.5",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.6.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18"
  }
}
